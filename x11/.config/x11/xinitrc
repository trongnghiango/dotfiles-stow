#!/usr/bin/env sh

# ==============================================================================
# 1. KHỞI TẠO MÔI TRƯỜNG CƠ BẢN & D-BUS (BẮT BUỘC)
# ==============================================================================

# Khởi chạy D-Bus Session (Chỉ khởi chạy nếu chưa có)
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
  eval $(dbus-launch --sh-syntax --exit-with-session)
fi

# Cập nhật biến môi trường hệ thống cho D-Bus (Sửa lỗi theme con trỏ, fcitx, app phẳng...)
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd DISPLAY XAUTHORITY --all
fi

# Khởi động GTK Portal thông minh (Hỗ trợ mở file nhanh cho Obsidian/Electron)
for portal_path in "/usr/lib/xdg-desktop-portal-gtk" "/usr/libexec/xdg-desktop-portal-gtk"; do
  if [ -f "$portal_path" ]; then
    if command -v xdg-desktop-portal >/dev/null 2>&1; then
      xdg-desktop-portal &
    fi
    "$portal_path" &
    break
  fi
done

# Nạp cấu hình cá nhân (.xprofile)
if [ -f "${XDG_CONFIG_HOME:-$HOME/.config}/x11/xprofile" ]; then
  . "${XDG_CONFIG_HOME:-$HOME/.config}/x11/xprofile"
elif [ -f "$HOME/.xprofile" ]; then
  . "$HOME/.xprofile"
fi

# ==============================================================================
# 2. ỨNG DỤNG NỀN (BACKGROUND SERVICES)
# ==============================================================================

# Xác thực quyền GUI độc lập và siêu nhẹ (Polkit Agent)
if [ -f /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 ]; then
  /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
elif command -v lxpolkit >/dev/null 2>&1; then
  lxpolkit &
fi

# Quản lý Clipboard (Tránh mất lịch sử sao lưu trên DWM)
if command -v copyq >/dev/null 2>&1; then
  copyq &
fi

# Trình quản lý năng lượng (Tự động hóa việc ngủ khi gập màn hình laptop)
if command -v xfce4-power-manager >/dev/null 2>&1; then
  xfce4-power-manager &
fi

# Trayer: Khay hệ thống tối giản (Chỉ chạy duy nhất 1 tiến trình)
if ! pgrep -x "trayer" >/dev/null; then
  trayer --edge top --align left --widthtype request --padding 0 \
    --SetDockType true --tint 0x222222 --height 24 \
    --transparent true --alpha 0 &
fi

# ==============================================================================
# 3. QUẢN LÝ THIẾT BỊ & ÂM THANH (ARCH vs NIXOS)
# ==============================================================================

USER_ID=$(id -u)

check_and_run() {
  if ! pgrep -x "$1" >/dev/null; then
    "$@" &
  fi
}

# Tự động gỡ và gắn các thiết bị lưu trữ (USB, ổ cứng di động)
if command -v udiskie >/dev/null 2>&1; then
  udiskie &
fi

if [ -f /etc/nixos/configuration.nix ]; then
  # NixOS: Khởi động lại dịch vụ qua Systemd User
  systemctl --user reset-failed pipewire wireplumber pipewire-pulse 2>/dev/null
  systemctl --user restart pipewire wireplumber pipewire-pulse
else
  # Arch/Void: Khởi động Pipewire tuần tự thủ công để tránh lỗi mất tiếng
  if [ ! -e "/run/user/$USER_ID/pipewire-0" ] && pgrep -x pipewire >/dev/null; then
    killall -9 pipewire pipewire-pulse wireplumber 2>/dev/null
    sleep 1
  fi

  check_and_run pipewire
  sleep 1
  check_and_run wireplumber
  check_and_run pipewire-pulse
fi

# Gửi tín hiệu cập nhật âm lượng lên dwmblocks sau khi khởi động ổn định 3s
(sleep 3 && pkill -RTMIN+11 dwmblocks) &

# ==============================================================================
# 4. KHỞI ĐỘNG DWM
# ==============================================================================

# Chạy DWM thông qua SSH Agent bằng biến PATH an toàn
exec ssh-agent dwm
