#!/bin/sh

case $BLOCK_BUTTON in
    1) notify-send "🧠 Memory hogs" "$(ps axch -o cmd:15,%mem --sort=-%mem | head)" ;;
    2) ifinstalled btop && setsid -f st -e btop ;;
    3) notify-send "🧠 Memory module" "\- Shows Memory Used/Total.\n- Click to show memory hogs.\n- Middle click to open htop." ;;
esac

# Optimized one-liner
mem=$(free -h | awk '/^Mem:/ {print $3}' | sed 's/i//g')

# Keep your format colors
echo "^C11^ ^C15^$mem"
