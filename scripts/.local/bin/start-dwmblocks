#!/bin/sh

# ==============================================================================
# CONFIGURATION
# ==============================================================================
PROG="dwmblocks"
# Nạp đường dẫn script con (Quan trọng)
export PATH="$HOME/.local/bin:$PATH"
export DISPLAY=:0

# ==============================================================================
# FUNCTIONS
# ==============================================================================

# Hàm dọn dẹp: Giết sạch sẽ mọi thứ liên quan
cleanup() {
  echo "🧹 Cleaning up old processes..."
  # Giết dwmblocks
  killall -9 "$PROG" >/dev/null 2>&1

  # Giết luôn tất cả các script con (ka-*) đang chạy ngầm
  # Lệnh này tìm tất cả process có tên ka- và giết sạch
  pkill -9 -f "ka-" >/dev/null 2>&1

  # Giết cả slstatus/conky nếu có
  killall -9 slstatus conky >/dev/null 2>&1

  sleep 0.5
}

# Hàm chạy chương trình
_launch() {
  # Chạy tách biệt khỏi terminal (setsid), ẩn output rác (> /dev/null)
  # Nếu dwmblocks của bạn cần pipe (in ra stdout), hãy bỏ comment dòng dưới và comment dòng setsid
  # "$PROG" | xargs -0 -I {} xsetroot -name "{}" &

  setsid "$PROG" >/dev/null 2>&1 &
}

launch() {
  # Cách cũ (setsid) có vẻ đang gây lỗi với bản build của bạn.
  # Hãy dùng cách này: Chuyển hướng output vào xsetroot.

  # 1. Chạy dwmblocks
  # 2. Dùng xargs để bắt lấy chữ in ra và ném lên thanh bar
  # 3. Chạy nền (&)

  "$PROG" | while read -r line; do xsetroot -name "$line"; done &
}

# Hàm hiển thị trạng thái đang khởi động (Visual Feedback)
show_loading() {
  # Yêu cầu cài gói: xorg-xsetroot
  xsetroot -name "♻️  Restarting Statusbar..."
}

# ==============================================================================
# MAIN LOGIC
# ==============================================================================

case "$1" in
"reload" | "restart")
  echo "🔄 [RESTART MODE] Killing old processes..."
  cleanup

  echo "⏳ Updating visual feedback..."
  show_loading
  sleep 0.5 # Giữ chữ Restarting một chút để mắt kịp nhìn thấy

  echo "🚀 Launching new instance..."
  launch

  notify-send "DWMBlocks" "Đã khởi động lại thành công!"
  exit 0
  ;;

*)
  # Chế độ Autostart (khi login)
  if pgrep -x "$PROG" >/dev/null; then
    echo "✅ [AUTOSTART] $PROG is already running. Skipping."
    exit 0
  else
    echo "🚀 [AUTOSTART] Starting $PROG..."
    # Dọn dẹp sơ bộ đề phòng process ma
    cleanup
    launch
  fi
  ;;
esac
