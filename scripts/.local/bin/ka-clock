#!/bin/sh

hour=$(date '+%I')

case "$hour" in
    "00"|"12") icon="🕛" ;;
    "01") icon="🕐" ;;
    "02") icon="🕑" ;;
    "03") icon="🕒" ;;
    "04") icon="🕓" ;;
    "05") icon="🕔" ;;
    "06") icon="🕕" ;;
    "07") icon="🕖" ;;
    "08") icon="🕗" ;;
    "09") icon="🕘" ;;
    "10") icon="🕙" ;;
    "11") icon="🕚" ;;
esac

case $BLOCK_BUTTON in
    1) notify-send "Calendar" "$(cal | sed "s/\<$(date +'%e' | tr -d ' ')\>/<b><span color='red'>&<\/span><\/b>/")" ;;
    2) ifinstalled calcurse && setsid -f "$TERMINAL" -e calcurse ;;
    3) notify-send "📅 Time" "Left: Month view\nMiddle: Calcurse" ;;
    6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

echo "$icon$(date '+%I:%M%P')"
