#!/usr/bin/env sh

# Kiểm tra xem wpctl có tồn tại không để tránh lỗi treo script
if ! command -v wpctl >/dev/null 2>&1; then
    echo "No wpctl"
    exit 1
fi

# --- 1. XỬ LÝ CLICK/SCROLL ---
case $BLOCK_BUTTON in
1) setsid -f "$TERMINAL" -e pulsemixer ;; # Chuột trái: Mở Mixer
2)
  # Chuột giữa: Toggle Mute & Update ngay lập tức
  wpctl set-mute @DEFAULT_SINK@ toggle
  pkill -RTMIN+11 "${STATUSBAR:-dwmblocks}"
  ;;
4)
  # Lăn lên: Tăng 5% (1% quá chậm) & Update ngay
  wpctl set-volume -l 1.5 @DEFAULT_SINK@ 2%+
  pkill -RTMIN+11 "${STATUSBAR:-dwmblocks}"
  ;;
5)
  # Lăn xuống: Giảm 5% & Update ngay
  wpctl set-volume @DEFAULT_SINK@ 2%-
  pkill -RTMIN+11 "${STATUSBAR:-dwmblocks}"
  ;;
3) notify-send "📢 Volume module" "🖱 Middle: Mute\n🖱 Scroll: Change Volume" ;;
esac

# --- 2. LẤY DỮ LIỆU ---
# Lấy cả dòng info một lần cho nhanh, có timeout tránh treo trên VM
WP_OUTPUT=$(timeout 1s wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)

# --- 3. XỬ LÝ HIỂN THỊ ---
if [ -z "$WP_OUTPUT" ]; then
  # Trường hợp khởi động chưa xong -> Hiển thị tạm dấu 3 chấm thay vì icon lỗi
  echo "^C4^ ^C15^..."
  exit
fi

# Kiểm tra Mute: Nếu chuỗi chứa [MUTED]
if echo "$WP_OUTPUT" | grep -q "MUTED"; then
  echo "^C3^ ^C15^Muted"
  exit
fi

# Lọc lấy số Volume (Cắt chuỗi "Volume: 0.75" -> 0.75)
# Dùng awk xử lý an toàn hơn split/IFS
VOL_FLOAT=$(echo "$WP_OUTPUT" | awk '{print $2}')

# Chuyển đổi 0.75 -> 75 (Dùng awk để tính toán số học chuẩn xác)
VOL_INT=$(awk -v v="$VOL_FLOAT" 'BEGIN { printf "%.0f", v * 100 }')

# Chọn Icon theo mức độ
if [ "$VOL_INT" -ge 70 ]; then
  ICON="🔊"
elif [ "$VOL_INT" -ge 30 ]; then
  ICON="🔉"
else
  ICON="🔈"
fi

# In ra kết quả (Thêm màu sắc cho đẹp nếu muốn)
# ^C4^ là màu xanh dương (tùy palette), ^C15^ trắng
echo "^C4^$ICON^C15^$VOL_INT%"
