{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "9Router Gateway",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:ROUTER9_API_KEY}"
      },
      "models": {
        "KhaBoDo_1.0": {
          "name": "KhaBoDo (Main Combo)",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "KhaSimple": {
          "name": "KhaSimple (Simple Combo)",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "KhaThinking": {
          "name": "KhaThinking (Thinking Combo)",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "9router/KhaBoDo_1.0",
  "small_model": "9router/KhaSimple",
  "agent": {
    "explorer": {
      "description": "Fast explorer — dùng combo đơn giản",
      "mode": "subagent",
      "model": "9router/KhaSimple"
    },
    "thinker": {
      "description": "Suy luận sâu — dùng combo thinking",
      "mode": "subagent",
      "model": "9router/KhaThinking"
    }
  }
}
